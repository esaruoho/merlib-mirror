13484, "no_speech_prob": 2.2345755454344918e-11}, {"id": 37, "seek": 11464, "start": 123.88, "end": 128.42000000000002, "text": " You know, the strange thing, though, is I haven't heard hide nor hair about this from", "tokens": [50827, 509, 458, 11, 264, 5861, 551, 11, 1673, 11, 307, 286, 2378, 380, 2198, 6479, 6051, 2578, 466, 341, 490, 51054], "temperature": 0.0, "avg_logprob": -0.23523127131101465, "compression_ratio": 1.5842696629213484, "no_speech_prob": 2.2345755454344918e-11}, {"id": 38, "seek": 11464, "start": 128.42000000000002, "end": 129.42000000000002, "text": " the government.", "tokens": [51054, 264, 2463, 13, 51104], "temperature": 0.0, "avg_logprob": -0.23523127131101465, "compression_ratio": 1.5842696629213484, "no_speech_prob": 2.2345755454344918e-11}, {"id": 39, "seek": 11464, "start": 129.42000000000002, "end": 132.52, "text": " So if MIT has it, maybe they're sitting on it or something.", "tokens": [51104, 407, 498, 13100, 575, 309, 11, 1310, 436, 434, 3798, 322, 309, 420, 746, 13, 51259], "temperature": 0.0, "avg_logprob": -0.23523127131101465, "compression_ratio": 1.5842696629213484, "no_speech_prob": 2.2345755454344918e-11}, {"id": 40, "seek": 11464, "start": 132.52, "end": 139.32, "text": " Well, no, MIT released it about the same time as we had OPEC at our house talking to", "tokens": [51259, 1042, 11, 572, 11, 13100, 4736, 309, 466, 264, 912, 565, 382, 321, 632, 422, 5208, 34, 412, 527, 1782, 1417, 281, 51599], "temperature": 0.0, "avg_logprob": -0.23523127131101465, "compression_ratio": 1.5842696629213484, "no_speech_prob": 2.2345755454344918e-11}, {"id": 41, "seek": 11464, "start": 139.32, "end": 140.64, "text": " us.", "tokens": [51599, 505, 13, 51665], "temperature": 0.0, "avg_logprob": -0.23523127131101465, "compression_ratio": 1.5842696629213484, "no_speech_prob": 2.2345755454344918e-11}, {"id": 42, "seek": 14064, "start": 140.64, "end": 144.0, "text": " When they released it publicly in November of 1999,", "tokens": [50365, 1133, 436, 4736, 309, 14843, 294, 7674, 295, 19952, 11, 50533], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 43, "seek": 14064, "start": 144.0, "end": 147.01999999999998, "text": " they were attacked by university professors all over Europe", "tokens": [50533, 436, 645, 12692, 538, 5454, 15924, 439, 670, 3315, 50684], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 44, "seek": 14064, "start": 147.01999999999998, "end": 149.26, "text": " who had written letters to the Nobel Prize Committee", "tokens": [50684, 567, 632, 3720, 7825, 281, 264, 24611, 22604, 11556, 50796], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 45, "seek": 14064, "start": 149.26, "end": 152.45999999999998, "text": " saying that my wife and I should be nominated for the Nobel", "tokens": [50796, 1566, 300, 452, 3836, 293, 286, 820, 312, 25159, 337, 264, 24611, 50956], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 46, "seek": 14064, "start": 152.45999999999998, "end": 152.95999999999998, "text": " Prize.", "tokens": [50956, 22604, 13, 50981], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 47, "seek": 14064, "start": 152.95999999999998, "end": 154.29999999999998, "text": " Well, again, it's highly demonstrable.", "tokens": [50981, 1042, 11, 797, 11, 309, 311, 5405, 5516, 424, 638, 13, 51048], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 48, "seek": 14064, "start": 154.29999999999998, "end": 155.33999999999997, "text": " Highly demonstrable.", "tokens": [51048, 5229, 356, 5516, 424, 638, 13, 51100], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 49, "seek": 14064, "start": 155.33999999999997, "end": 156.39999999999998, "text": " That has street cred.", "tokens": [51100, 663, 575, 4838, 3864, 13, 51153], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 50, "seek": 14064, "start": 156.39999999999998, "end": 158.26, "text": " But then they turned around and attacked MIT,", "tokens": [51153, 583, 550, 436, 3574, 926, 293, 12692, 13100, 11, 51246], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 51, "seek": 14064, "start": 158.26, "end": 159.79999999999998, "text": " saying, you're a bunch of thieves.", "tokens": [51246, 1566, 11, 291, 434, 257, 3840, 295, 37057, 13, 51323], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 52, "seek": 14064, "start": 159.79999999999998, "end": 160.48, "text": " That isn't yours.", "tokens": [51323, 663, 1943, 380, 6342, 13, 51357], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 53, "seek": 14064, "start": 160.48, "end": 161.83999999999997, "text": " That's Paul Pantone's.", "tokens": [51357, 663, 311, 4552, 430, 394, 546, 311, 13, 51425], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 54, "seek": 14064, "start": 161.83999999999997, "end": 164.16, "text": " You know, I'd heard something similar from Eugene Malove", "tokens": [51425, 509, 458, 11, 286, 1116, 2198, 746, 2531, 490, 37059, 5746, 1682, 51541], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 55, "seek": 14064, "start": 164.16, "end": 166.01999999999998, "text": " about MIT a while back.", "tokens": [51541, 466, 13100, 257, 1339, 646, 13, 51634], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 56, "seek": 14064, "start": 166.01999999999998, "end": 167.89999999999998, "text": " Yes, as a matter of fact, a couple of weeks", "tokens": [51634, 1079, 11, 382, 257, 1871, 295, 1186, 11, 257, 1916, 295, 3259, 51728], "temperature": 0.0, "avg_logprob": -0.2341937654337306, "compression_ratio": 1.6231884057971016, "no_speech_prob": 3.3184472964659095e-12}, {"id": 57, "seek": 16790, "start": 167.9, "end": 170.68, "text": " before he was murdered, Eugene called me up", "tokens": [50365, 949, 415, 390, 18486, 11, 37059, 1219, 385, 493, 50504], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 58, "seek": 16790, "start": 170.68, "end": 172.20000000000002, "text": " and gave me the names and phone numbers", "tokens": [50504, 293, 2729, 385, 264, 5288, 293, 2593, 3547, 50580], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 59, "seek": 16790, "start": 172.20000000000002, "end": 174.56, "text": " of a lot of other scientists from MIT", "tokens": [50580, 295, 257, 688, 295, 661, 7708, 490, 13100, 50698], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 60, "seek": 16790, "start": 174.56, "end": 177.02, "text": " that would probably financially back this.", "tokens": [50698, 300, 576, 1391, 20469, 646, 341, 13, 50821], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 61, "seek": 16790, "start": 177.02, "end": 179.42000000000002, "text": " But he said, the strings are every university", "tokens": [50821, 583, 415, 848, 11, 264, 13985, 366, 633, 5454, 50941], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 62, "seek": 16790, "start": 179.42000000000002, "end": 181.56, "text": " wants to have their name on a technology,", "tokens": [50941, 2738, 281, 362, 641, 1315, 322, 257, 2899, 11, 51048], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 63, "seek": 16790, "start": 181.56, "end": 183.46, "text": " and they want the inventor's name removed.", "tokens": [51048, 293, 436, 528, 264, 41593, 311, 1315, 7261, 13, 51143], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 64, "seek": 16790, "start": 183.46, "end": 184.64000000000001, "text": " Sure, sure.", "tokens": [51143, 4894, 11, 988, 13, 51202], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 65, "seek": 16790, "start": 184.64000000000001, "end": 186.32, "text": " He warned me of this ahead of time.", "tokens": [51202, 634, 21284, 385, 295, 341, 2286, 295, 565, 13, 51286], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 66, "seek": 16790, "start": 186.32, "end": 188.02, "text": " Yeah, but you are nonetheless making", "tokens": [51286, 865, 11, 457, 291, 366, 26756, 1455, 51371], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 67, "seek": 16790, "start": 188.02, "end": 189.02, "text": " wonderful progress with it.", "tokens": [51371, 3715, 4205, 365, 309, 13, 51421], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 68, "seek": 16790, "start": 189.02, "end": 189.74, "text": " It's a wonderful tool.", "tokens": [51421, 467, 311, 257, 3715, 2290, 13, 51457], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 69, "seek": 16790, "start": 189.74, "end": 191.0, "text": " It's now being taught in Paris.", "tokens": [51457, 467, 311, 586, 885, 5928, 294, 8380, 13, 51520], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 70, "seek": 16790, "start": 191.0, "end": 193.5, "text": " There's a classroom over there teaching it.", "tokens": [51520, 821, 311, 257, 7419, 670, 456, 4571, 309, 13, 51645], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 71, "seek": 16790, "start": 193.5, "end": 195.86, "text": " We've had people getting engineering degrees in Europe,", "tokens": [51645, 492, 600, 632, 561, 1242, 7043, 5310, 294, 3315, 11, 51763], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 72, "seek": 16790, "start": 195.86, "end": 197.14000000000001, "text": " but not here.", "tokens": [51763, 457, 406, 510, 13, 51827], "temperature": 0.0, "avg_logprob": -0.18976590556483114, "compression_ratio": 1.6253521126760564, "no_speech_prob": 2.223244375057498e-12}, {"id": 73, "seek": 19714, "start": 197.14, "end": 199.83999999999997, "text": " And we're accepted into European universities and not here.", "tokens": [50365, 400, 321, 434, 9035, 666, 6473, 11779, 293, 406, 510, 13, 50500], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}, {"id": 74, "seek": 19714, "start": 200.27999999999997, "end": 202.89999999999998, "text": " Yeah, I've heard that also with a number of different technologies.", "tokens": [50522, 865, 11, 286, 600, 2198, 300, 611, 365, 257, 1230, 295, 819, 7943, 13, 50653], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}, {"id": 75, "seek": 19714, "start": 203.64, "end": 207.98, "text": " So right now we're gearing up to start worldwide production outside of the United States.", "tokens": [50690, 407, 558, 586, 321, 434, 1519, 1921, 493, 281, 722, 13485, 4265, 2380, 295, 264, 2824, 3040, 13, 50907], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}, {"id": 76, "seek": 19714, "start": 208.51999999999998, "end": 208.88, "text": " Absolutely.", "tokens": [50934, 7021, 13, 50952], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}, {"id": 77, "seek": 19714, "start": 209.04, "end": 211.76, "text": " Well, again, you're Paul Pantone, and this is the Geet Technology,", "tokens": [50960, 1042, 11, 797, 11, 291, 434, 4552, 430, 394, 546, 11, 293, 341, 307, 264, 2876, 302, 15037, 11, 51096], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}, {"id": 78, "seek": 19714, "start": 211.95999999999998, "end": 215.32, "text": " and you're online at geetget.com.", "tokens": [51106, 293, 291, 434, 2950, 412, 1519, 302, 847, 13, 1112, 13, 51274], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}, {"id": 79, "seek": 19714, "start": 215.32, "end": 216.01999999999998, "text": " You got it.", "tokens": [51274, 509, 658, 309, 13, 51309], "temperature": 0.0, "avg_logprob": -0.23445435787769073, "compression_ratio": 1.4741379310344827, "no_speech_prob": 2.327564790211012e-12}], "language": "en"}