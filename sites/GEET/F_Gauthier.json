 -0.34265578234637223, "compression_ratio": 1.308724832214765, "no_speech_prob": 4.585028537396063e-12}, {"id": 31, "seek": 25608, "start": 262.24, "end": 269.82, "text": " va continuer \u00e0 tourner pareil. Ok, donc on va commencer l'experience. Donc je mets un petit peu", "tokens": [50673, 2773, 35660, 1531, 3512, 1193, 46020, 13, 3477, 11, 5926, 322, 2773, 32817, 287, 6, 3121, 610, 1182, 13, 7477, 1506, 37231, 517, 9686, 5604, 51052], "temperature": 0.0, "avg_logprob": -0.34265578234637223, "compression_ratio": 1.308724832214765, "no_speech_prob": 4.585028537396063e-12}, {"id": 32, "seek": 26982, "start": 269.82, "end": 277.4, "text": " Essence to it, now. And that's it.", "tokens": [50365, 14357, 655, 281, 309, 11, 586, 13, 400, 300, 311, 309, 13, 50744], "temperature": 1.0, "avg_logprob": -2.234577178955078, "compression_ratio": 0.8292682926829268, "no_speech_prob": 6.62409233367911e-12}, {"id": 33, "seek": 29982, "start": 299.82, "end": 329.8, "text": " Thank you.", "tokens": [50365, 1044, 291, 13, 51864], "temperature": 0.0, "avg_logprob": -0.48773133754730225, "compression_ratio": 0.5555555555555556, "no_speech_prob": 8.971183518280412e-11}, {"id": 34, "seek": 32982, "start": 329.82, "end": 359.8, "text": " So, let's go.", "tokens": [50365, 407, 11, 718, 311, 352, 13, 51864], "temperature": 0.0, "avg_logprob": -0.7967069413926866, "compression_ratio": 0.6190476190476191, "no_speech_prob": 1.3898700246262052e-10}, {"id": 35, "seek": 35982, "start": 359.82, "end": 389.8, "text": " Thank you.", "tokens": [50365, 1044, 291, 13, 51864], "temperature": 0.0, "avg_logprob": -0.6448706785837809, "compression_ratio": 0.5555555555555556, "no_speech_prob": 7.001539625850484e-11}, {"id": 36, "seek": 38982, "start": 389.82, "end": 419.8, "text": " Thank you.", "tokens": [50365, 1044, 291, 13, 51864], "temperature": 0.0, "avg_logprob": -0.6101884047190348, "compression_ratio": 0.5555555555555556, "no_speech_prob": 4.5701151196730905e-11}, {"id": 37, "seek": 41982, "start"