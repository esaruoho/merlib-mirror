#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
PENDING_DIR="$REPO_DIR/queue/pending"

usage() {
  cat <<'EOF'
MERLib Mirror — Mirroring the Internet's Modern Energy Research into a Library

Usage:
  mirror-submit DOMAIN                # Mirror domain via Wayback Machine
  mirror-submit URL                   # Auto-detect mode (wayback or live)
  mirror-submit GDRIVE_URL            # Download Google Drive folder/file
  mirror-submit --no-push TARGET      # Queue locally without git push
  mirror-submit status                # Show queue status

Options:
  --no-push         Skip git commit+push (for bot use)
  --label NAME      Custom directory name (for gdrive, replaces gdrive-ID)
  -h, --help        Show this help

Examples:
  mirror-submit riess.org
  mirror-submit https://web.archive.org/web/2022/https://cheniere.org/
  mirror-submit https://some-live-site.org
  mirror-submit https://drive.google.com/drive/folders/FOLDER_ID
  mirror-submit --label don-smith-papers https://drive.google.com/drive/folders/FOLDER_ID
EOF
  exit 0
}

extract_domain() {
  local input="$1"

  # Wayback URL → extract domain
  if [[ "$input" =~ web\.archive\.org/web/[^/]+/(https?://)?([^/]+) ]]; then
    local d="${BASH_REMATCH[2]}"
    # Strip www.
    d="${d#www.}"
    echo "$d"
    return 0
  fi

  # Google Drive URL → extract folder/file ID as "domain"
  if [[ "$input" =~ drive\.google\.com/drive/folders/([a-zA-Z0-9_-]+) ]]; then
    echo "gdrive-${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "$input" =~ drive\.google\.com/file/d/([a-zA-Z0-9_-]+) ]]; then
    echo "gdrive-${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "$input" =~ drive\.google\.com.*[?&]id=([a-zA-Z0-9_-]+) ]]; then
    echo "gdrive-${BASH_REMATCH[1]}"
    return 0
  fi

  # Full URL → extract domain
  if [[ "$input" =~ ^https?://([^/]+) ]]; then
    local d="${BASH_REMATCH[1]}"
    d="${d#www.}"
    echo "$d"
    return 0
  fi

  # Bare domain (has a dot, no slashes)
  if [[ "$input" == *.* && "$input" != */* ]]; then
    echo "$input"
    return 0
  fi

  # domain/path format (e.g. padrak.com/ine)
  if [[ "$input" == *.* && "$input" == */* && ! "$input" =~ ^https?:// ]]; then
    echo "${input%%/*}"
    return 0
  fi

  return 1
}

extract_wayback_timestamp() {
  local input="$1"
  if [[ "$input" =~ web\.archive\.org/web/([0-9]+) ]]; then
    echo "${BASH_REMATCH[1]:0:8}"  # YYYYMMDD
    return
  fi
  echo ""
}

extract_path_filter() {
  local input="$1"
  local domain="$2"

  # From "domain/path" style input (e.g. padrak.com/ine)
  if [[ "$input" == "${domain}/"* ]]; then
    local path="${input#${domain}}"
    echo "$path"
    return
  fi

  # From Wayback URL: extract path after domain
  if [[ "$input" =~ web\.archive\.org ]]; then
    # Extract the original URL from the wayback URL, then get its path
    local orig_url=""
    if [[ "$input" =~ web\.archive\.org/web/[^/]+/(https?://[^/]+)(/.*)$ ]]; then
      local path_part="${BASH_REMATCH[2]}"
      path_part="$(echo "$path_part" | sed 's|/\*$||; s|/$||')"
      if [[ -n "$path_part" && "$path_part" != "/" ]]; then
        echo "$path_part"
        return
      fi
      echo ""
      return
    fi
    # Try simpler: everything after domain in the target part
    local after_domain
    after_domain="$(echo "$input" | sed -n "s|.*${domain}\(/[^*]*\).*|\1|p" | sed 's|/$||')"
    if [[ -n "$after_domain" && "$after_domain" != "/" ]]; then
      echo "$after_domain"
      return
    fi
  fi

  # From full URL with path
  if [[ "$input" =~ ^https?://[^/]+(/.+) ]]; then
    local path="${BASH_REMATCH[1]}"
    if [[ "$path" != "/" ]]; then
      echo "$path" | sed 's|/$||'
      return
    fi
  fi

  echo ""
}

detect_mode() {
  local input="$1"

  # Wayback URL → wayback mode
  if [[ "$input" =~ web\.archive\.org ]]; then
    echo "wayback"
    return
  fi

  # Google Drive URL → gdrive mode
  if [[ "$input" =~ drive\.google\.com ]]; then
    echo "gdrive"
    return
  fi

  # Bare domain or domain/path → wayback mode
  if [[ "$input" == *.* && ! "$input" =~ ^https?:// ]]; then
    echo "wayback"
    return
  fi

  # Full URL → live mode
  if [[ "$input" =~ ^https?:// ]]; then
    echo "live"
    return
  fi

  echo "unknown"
}

queue_job() {
  local target="$1"
  local domain="$2"
  local mode="$3"
  local path_filter="$4"

  # Check for duplicate pending jobs (match domain + path_filter)
  local search_key="domain: $domain"
  if grep -rql "$search_key" "$REPO_DIR/queue/" 2>/dev/null; then
    # If path_filter differs, it's a different job
    if [[ -z "$path_filter" ]] || grep -rql "path_filter: $path_filter" "$REPO_DIR/queue/" 2>/dev/null; then
      echo "  Skipped (already queued): $domain${path_filter}"
      return 1
    fi
  fi

  local ts
  ts="$(date +%s)"
  local safe_name="${domain}${path_filter//\//_}"
  local filename="${ts}_${safe_name}.job"
  local filepath="$PENDING_DIR/$filename"

  local ts_to="$5"

  local label="$6"

  cat > "$filepath" <<JOBEOF
target: $target
domain: $domain
mode: $mode
path_filter: $path_filter
ts_to: $ts_to
label: $label
submitted: $(date -u +%Y-%m-%dT%H:%M:%SZ)
submitted_from: $(hostname -s)
JOBEOF

  echo "  Queued: $domain ($mode mode) -> $filename"
  return 0
}

show_status() {
  local pending processing done failed
  pending=$(find "$REPO_DIR/queue/pending" -name '*.job' 2>/dev/null | wc -l | tr -d ' ')
  processing=$(find "$REPO_DIR/queue/processing" -name '*.job' 2>/dev/null | wc -l | tr -d ' ')
  done=$(find "$REPO_DIR/queue/done" -name '*.job' 2>/dev/null | wc -l | tr -d ' ')
  failed=$(find "$REPO_DIR/queue/failed" -name '*.job' 2>/dev/null | wc -l | tr -d ' ')

  echo "MERLib Mirror Queue Status"
  echo "Pending:    $pending"
  echo "Processing: $processing"
  echo "Done:       $done"
  echo "Failed:     $failed"

  # Show what's currently processing
  if [[ "$processing" -gt 0 ]]; then
    echo ""
    echo "Currently processing:"
    for f in "$REPO_DIR/queue/processing"/*.job; do
      [[ -f "$f" ]] || continue
      local d
      d="$(grep '^domain:' "$f" | head -1 | sed 's/^domain: *//')"
      echo "  $d"
    done
  fi

  # Show pending queue
  if [[ "$pending" -gt 0 ]]; then
    echo ""
    echo "Pending:"
    for f in "$REPO_DIR/queue/pending"/*.job; do
      [[ -f "$f" ]] || continue
      local d
      d="$(grep '^domain:' "$f" | head -1 | sed 's/^domain: *//')"
      echo "  $d"
    done
  fi
}

# --- Parse arguments ---

DO_PUSH=true
LABEL=""
TARGETS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-push)
      DO_PUSH=false
      shift
      ;;
    --label)
      LABEL="$2"
      shift 2
      ;;
    -h|--help) usage ;;
    status)
      show_status
      exit 0
      ;;
    -*)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
    *)
      TARGETS+=("$1")
      shift
      ;;
  esac
done

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  echo "Error: No target provided." >&2
  echo "Run 'mirror-submit --help' for usage." >&2
  exit 1
fi

# --- Queue each target ---

queued=0
for target in "${TARGETS[@]}"; do
  domain="$(extract_domain "$target")" || {
    echo "  Skipped (cannot extract domain): $target" >&2
    continue
  }

  mode="$(detect_mode "$target")"
  if [[ "$mode" == "unknown" ]]; then
    echo "  Skipped (cannot detect mode): $target" >&2
    continue
  fi

  # --label overrides the domain (directory name) for gdrive jobs
  if [[ -n "$LABEL" && "$mode" == "gdrive" ]]; then
    domain="$LABEL"
  fi

  path_filter="$(extract_path_filter "$target" "$domain")"
  ts_to="$(extract_wayback_timestamp "$target")"

  if queue_job "$target" "$domain" "$mode" "$path_filter" "$ts_to" "$LABEL"; then
    ((queued++)) || true
  fi
done

echo ""
echo "Queued $queued new mirror job(s)."

if [[ "$queued" -gt 0 && "$DO_PUSH" == true ]]; then
  cd "$REPO_DIR"
  git add queue/pending/
  git commit -m "queue: mirror $queued domain(s)"
  git push
  echo "Pushed to remote."
fi

if [[ "$queued" -gt 0 ]]; then
  # Wake the worker if it is sleeping
  PIDFILE="$REPO_DIR/.worker.pid"
  if [[ -f "$PIDFILE" ]]; then
    WORKER_PID=$(cat "$PIDFILE")
    if kill -0 "$WORKER_PID" 2>/dev/null; then
      kill -USR1 "$WORKER_PID" 2>/dev/null && echo "Woke mirror-worker (PID $WORKER_PID)"
    fi
  fi
fi
